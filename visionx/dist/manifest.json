{
  "manifest_version": 3,
  "name": "VisionX",
  "version": "0.1.0",
  "description": "Real-time accessibility enhancements for clearer, voice-assisted web reading.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "VisionX",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "report.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
